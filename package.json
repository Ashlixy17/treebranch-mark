{
  "name": "treebranch-mark",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.19.0"
  },
  "bin": {
    "treebranch": "./dist-cli/treebranch.js"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run build:cli && npm run build:web && npm run verify:build-boundaries",
    "build:web": "vite build",
    "build:cli": "vite build --config vite.cli.config.ts",
    "verify:build-boundaries": "node scripts/verify-build-boundaries.mjs",
    "lint": "oxlint",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.9"
  }
}
